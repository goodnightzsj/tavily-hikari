{
  "name": "tavily-hikari-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --bun ./node_modules/.bin/vite",
    "build": "bun --bun ./node_modules/.bin/tsc -b && bun --bun ./node_modules/.bin/vite build && bun ./scripts/write-version.mjs",
    "storybook": "bun --bun ./node_modules/.bin/storybook dev --host 127.0.0.1 --port 56006 --disable-telemetry",
    "storybook:ci": "bun --bun ./node_modules/.bin/storybook dev --ci --no-open --host 127.0.0.1 --port 56006 --disable-telemetry",
    "build-storybook": "bun --bun ./node_modules/.bin/storybook build --disable-telemetry",
    "preview": "bun --bun ./node_modules/.bin/vite preview",
    "test": "bun test"
  },
  "dependencies": {
    "@iconify/react": "^4.1.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-router": "^1.76.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.2.10",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "storybook": "10.2.10",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
